#include <iostream>
#include <vector>
int main() {
    std::vector<std::vector<int>> mat = {{1,2,3},{4,5,6},{7,8,9}};
    int n = mat.size();
    for(int i=0;i<n;i++) for(int j=i;j<n;j++) std::swap(mat[i][j], mat[j][i]);
    for(auto &row: mat){ for(auto x: row) std::cout<<x<<" "; std::cout<<"\n"; }
}
