#include <iostream>
#include <ctime>
using namespace std;

int main() {
    srand(time(0));
    string choices[] = {"rock", "paper", "scissors"};
    string user;
    cout << "Enter rock, paper, or scissors: "; cin >> user;

    string computer = choices[rand() % 3];
    cout << "Computer chose: " << computer << endl;

    if (user == computer) cout << "It's a tie!";
    else if ((user == "rock" && computer == "scissors") || 
             (user == "paper" && computer == "rock") || 
             (user == "scissors" && computer == "paper")) cout << "You win!";
    else cout << "Computer wins!";
    
    return 0;
}
