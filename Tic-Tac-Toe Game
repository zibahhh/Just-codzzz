#include <iostream>
using namespace std;

char board[3][3] = {{'1','2','3'}, {'4','5','6'}, {'7','8','9'}};
char turn = 'X';

void drawBoard() {
    for(int i=0; i<3; i++) {
        for(int j=0; j<3; j++) cout << board[i][j] << " ";
        cout << endl;
    }
}

void play() {
    int choice;
    cout << "Player " << turn << ", enter a number (1-9): ";
    cin >> choice;
    int row = (choice-1)/3, col = (choice-1)%3;
    if(board[row][col] != 'X' && board[row][col] != 'O') {
        board[row][col] = turn;
        turn = (turn == 'X') ? 'O' : 'X';
    } else { cout << "Box already filled! Try again.\n"; play(); }
}

int main() {
    for(int i=0; i<9; i++) { drawBoard(); play(); }
    drawBoard();
    return 0;
}
